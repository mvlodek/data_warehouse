# Financial Data Warehouse - Environment Configuration

# =============================================================================
# PostgreSQL Configuration
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=financial_data_warehouse
POSTGRES_USER=postgres
POSTGRES_PASSWORD=87654321

# =============================================================================
# MySQL Configuration  
# =============================================================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=financial_data_warehouse
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here

# =============================================================================
# MongoDB Configuration
# =============================================================================
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=financial_data_warehouse
MONGO_USER=
MONGO_PASSWORD=

# =============================================================================
# FMP API Configuration (Financial Modeling Prep)
# =============================================================================
FMP_API_KEY=your_fmp_api_key_here

# =============================================================================
# Application Settings
# =============================================================================
DEFAULT_DB=postgresql
LOG_LEVEL=INFO